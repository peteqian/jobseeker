{
  "name": "jobseeker",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --ui=tui",
    "lint": "oxlint --report-unused-disable-directives",
    "format": "oxfmt",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "turbo typecheck",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "^25.1.0",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "turbo": "^2.8.17",
    "typescript": "5.9.3",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.11"
}
