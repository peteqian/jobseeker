{
  "name": "server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/bin.ts",
    "build": "bun build src/bin.ts --target bun --outdir dist",
    "prepare": "effect-language-service patch",
    "fmt": "cd ../.. && oxfmt apps/server/src",
    "fmt:check": "cd ../.. && oxfmt --check apps/server/src",
    "format": "bun run fmt",
    "lint": "cd ../.. && oxlint --report-unused-disable-directives apps/server/src",
    "typecheck": "tsc --noEmit",
    "db:generate": "cd ../.. && drizzle-kit generate",
    "db:migrate": "cd ../.. && drizzle-kit migrate",
    "db:studio": "cd ../.. && drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@effect/platform-bun": "4.0.0-beta.45",
    "@effect/platform-node-shared": "4.0.0-beta.45",
    "@jobseeker/browser-agent": "workspace:*",
    "@jobseeker/contracts": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "effect": "4.0.0-beta.45",
    "hono": "^4.10.1",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "drizzle-kit": "^0.31.10",
    "typescript": "5.9.3",
    "vitest": "^4.0.0"
  }
}
