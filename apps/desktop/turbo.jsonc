{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist-electron/**"],
    },
    "dev": {
      "persistent": true,
      "cache": false,
    },
    "start": {
      "dependsOn": ["build", "web#build", "server#build"],
      "persistent": true,
      "cache": false,
    },
  },
}
